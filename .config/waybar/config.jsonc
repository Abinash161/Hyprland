// -*- mode: jsonc -*-
{
    // "layer": "top", // Waybar at top layer
    // "position": "bottom", // Waybar position (top|bottom|left|right)
    // "width": 1280, // Waybar width
    "spacing": 4, // Gaps between modules (4px)
    "position": "top",
    "margin": 0,
    "layer": "top",
    "exclusive": true,

    // Choose the order of the modules
    "modules-left": [
        "custom/arch",
	    "hyprland/workspaces",
        "custom/cava"
        // "custom/updates"
        //"sway/mode",
        //"sway/scratchpad"

    ],
    
    "modules-center": [
        "sway/window",
	"clock"
    ],
    "modules-right": [
        "custom/media",
        "custom/separator",
        "mpd",
        "pulseaudio",
	    "tray",
        "power-profiles-daemon",
        "cpu",
        //"memory",
        "backlight",
        //"keyboard-state",
        //"sway/language",
        "battery",
        //"battery#bat2",
        "custom/notifications",
        "custom/power"
    ],

    "custom/arch": {
        "format": " َ°£‡ ",
        "tooltip": true,
        "tooltip-format": "Specs",
        "on-click": "foot --app-id footfloat"
},

    // Modules configuration
"hyprland/workspaces": {
    "format": "{name}: {icon}",
    "format-icons": {
      "active": "ï†’",
      "default": "ï„‘"   },
    "all-outputs": true,
    "active-only": false,
    "persistent": true,
    "disable-scroll": true
},




    "keyboard-state": {
        "numlock": true,
        "capslock": true,
        "format": "{name} {icon}",
        "format-icons": {
            "locked": "ï€£",
            "unlocked": "ï‚œ"
        }
    },
    "sway/mode": {
        "format": "<span style=\"italic\">{}</span>"
    },
    "sway/scratchpad": {
        "format": "{icon} {count}",
        "show-empty": false,
        "format-icons": ["", "ï‹’"],
        "tooltip": true,
        "tooltip-format": "{app}: {title}"
    },
    "mpd": {
        "format": "{stateIcon} {consumeIcon}{randomIcon}{repeatIcon}{singleIcon}{artist} - {album} - {title} ({elapsedTime:%M:%S}/{totalTime:%M:%S}) â¸¨{songPosition}|{queueLength}â¸© {volume}% ï€پ",
        "format-disconnected": "Disconnected ï€پ",
        "format-stopped": "{consumeIcon}{randomIcon}{repeatIcon}{singleIcon}Stopped ï€پ",
        "unknown-tag": "N/A",
        "interval": 5,
        "consume-icons": {
            "on": "ïƒ„ "
        },
        "random-icons": {
            "off": "<span color=\"#f53c3c\">ïپ´</span> ",
            "on": "ïپ´ "
        },
        "repeat-icons": {
            "on": "ï€‍ "
        },
        "single-icons": {
            "on": "ï€‍1 "
        },
        "state-icons": {
            "paused": "ïپŒ",
            "playing": "ïپ‹"
        },
        "tooltip-format": "MPD (connected)",
        "tooltip-format-disconnected": "MPD (disconnected)"
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "ïپ®",
            "deactivated": "ïپ°"
        }
    },
    "tray": {
        // "icon-size": 21,
        "spacing": 22
        // "icons": {
        //   "blueman": "bluetooth",
        //   "TelegramDesktop": "$HOME/.local/share/icons/hicolor/16x16/apps/telegram.png"
        // }
    },
     "clock": {
        "timezone": "Asia/Kathmandu",
	"tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
   	 "format": "{:%H:%M:%S  -  %A, %d}",
   	"format-alt": "{:%Y-%m-%d}" ,
	"interval": 1
    	},


    "cpu": {
        "format": "{usage}% ï‹›",
        "tooltip": false
    },
    "memory": {
        "format": "{}% ïƒ‰"
    },
    "backlight": {
        // "device": "acpi_video1",
        "format": "{percent}% {icon}",
        "format-icons": ["îژچ", "îڈ“", "îڈ‘", "îڈڈ", "îڈژ", "îڈچ", "îڈٹ", "îڈˆ", "îژ›"]
    },
    "battery": {
        "states": {
            // "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{capacity}% {icon}",
        "format-full": "{capacity}% {icon}",
        "format-charging": "{capacity}% ï—§",
        "format-plugged": "{capacity}% ï‡¦",
        "format-alt": "{time} {icon}",
        // "format-good": "", // An empty format will hide the module
        // "format-full": "",
        "format-icons": ["ï‰„", "ï‰ƒ", "ï‰‚", "ï‰پ", "ï‰€"]
    },
    "battery#bat2": {
        "bat": "BAT2"
    },
    "power-profiles-daemon": {
      "format": "{icon}",
      "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
      "tooltip": true,
      "format-icons": {
        "default": "ïƒ§",
        "performance": "ïƒ§",
        "balanced": "ï‰ژ",
        "power-saver": "ïپ¬"
      }
    },
    
"network": {
	"format": "{ifname}",
	"format-wifi": "ï‡« ",
	"format-ethernet": "َ°Œک",
	"format-disconnected": "َ°Œ™",
	"tooltip-format": "{essid} ï‡« {signalStrength}%\n{ipaddr} ï„¹ {bandwidthUpBits} ï„؛ {bandwidthDownBits}",
	"format-linked": "ï‡« {ifname} (No IP)",
	"tooltip-format-ethernet": "{ifname} َ°Œک",
	"tooltip-format-disconnected": "َ°Œ™ Disconnected",
	"max-length": 30,
	"format-icons": ["ï‡«"],
    "on-click-right": "foot --app-id footfloat fish -ic 'nmtui; exec fish'",
	"signal-strength": {
		"bad": "#ff5555",      // red for weak
		"medium": "#f1fa8c",   // yellow for mid
		"good": "#50fa7b"      // green for strong
	}
},


  "pulseaudio": {
    // "scroll-step": 1, // %, can be a float
    "format": "{icon} {volume}%",
    "format-bluetooth": "{volume}% {icon}ïٹ” {format_source}",
    "format-bluetooth-muted": "ïڑ© {icon}ïٹ” {format_source}",
    "format-muted": "ïڑ© {format_source}",
    "format-source": "{volume}% ï„°",
    "format-source-muted": "ï„±",
    "format-icons": {
      "headphone": "ï€¥ ",
      "hands-free": "ï–گ ",
      "headset": "ï–گ ",
      "phone": "ï‚• ",
      "portable": "ï‚• ",
      "car": "ï†¹ ",
      "default": [
        "ï€¦",
        "ï€¨",
        "ï€¨"
      ]
    },
        "on-click":"wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
        "on-click-right":"pavucontrol"
    },

    "custom/media": {
    "format": "{icon} {text}",
    "return-type": "json",
    "max-length": 40,
    "format-icons": {
        "spotify": "ï†¼",
        "default": "ًںژœ"
    },
    "escape": true,
    "exec": "$HOME/.config/waybar/mediaplayer.py",
    "interval": 3,
    "restart-interval": 10,
    "on-click": "~/.config/waybar/mediaplayer-toggle.sh play-pause",
    "on-click-right": "~/.config/waybar/mediaplayer-toggle.sh next"
},

    "custom/power": {
        "format" : " âڈ» ",
		"tooltip": false,
		"on-click":"~/.config/wlogout/launch.sh"
	
    },
     // Separator module
    "custom/separator": {
        "format": "â”‚",
        "tooltip": false
        
    },
    "custom/cava": {
        "exec": "~/.config/waybar/cava.sh",
        "return-type": "json",
        "restart-interval": 1,
        "format": "{}",
        "on-click": "foot --app-id footfloat cava",
        "tooltip": false
    },
    "custom/notifications": {
        "format": "{text}",
        "return-type": "json",
        "exec": "~/.config/waybar/get-notifications.sh",
        "exec-on-event": false,
        "interval": 3,
        "on-click": "swaync-client -op",
        "on-click-right": "swaync-client -D",
        "tooltip": true,
        "tooltip-format": "Click to open\nRight-click to toggle DND"
    },
    "custom/updates": {
  "format": "{} {icon}",
  "return-type": "json",
  "format-icons": {
    "has-updates": "َ±چ·",
    "updated": "َ°‚ھ"
  },
  "exec-if": "which waybar-module-pacman-updates",
  "exec": "waybar-module-pacman-updates --interval-seconds 5 --network-interval-seconds 300"
}
}



